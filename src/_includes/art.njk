{# Topic artwork: seeded geometric pattern in the topic's color family with
   the topic icon on top. Colors come entirely from CSS keyed on data-t
   (light default + dark override) so the cascade works in both themes —
   no inline color, which would override the dark rule. #}
{%- macro art(topic, seed, topics) -%}
{%- set t = topic | lower -%}
{%- set ic = {
  "science": "ti-microscope",
  "philosophy": "ti-brain",
  "secularism": "ti-building-bank",
  "religion": "ti-book",
  "news": "ti-broadcast"
} -%}
<div class="art-field" data-t="{{ t }}" aria-hidden="true">
  {% topicPattern t, seed %}
  <i class="ti {{ ic[t] or 'ti-circle' }} art-icon"></i>
</div>
{%- endmacro -%}

{# thumb(post, topics): illustration if the post has one, else the tessellation.
   Accepts an Eleventy collection item (uses post.data.image / .topic, post.fileSlug). #}
{%- macro thumb(post, topics) -%}
{%- if post.data.image -%}
<img class="thumb-illustration" src="{{ post.data.image }}" alt="" loading="lazy">
{%- else -%}
{{ art(post.data.topic, post.fileSlug, topics) }}
{%- endif -%}
{%- endmacro -%}
