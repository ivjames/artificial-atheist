{# Topic-keyed artwork built from the topic's own icon + accent color.
   A consistent composition across all topics: the Tabler icon centered in a
   tinted field, framed by faint concentric rings in the topic color. The
   `--topic-color` and `--bg-tint` vars are set by the caller per theme, so
   the same markup adapts to light and dark automatically.
   `variant` rotates the ring/offset pattern so a grid of same-topic cards
   doesn't look identical. #}
{%- macro art(topic, variant) -%}
{%- set t = topic | lower -%}
{%- set ic = {
  "science": "ti-microscope",
  "philosophy": "ti-brain",
  "secularism": "ti-building-bank",
  "religion": "ti-book",
  "news": "ti-broadcast"
} -%}
{%- set icon = ic[t] or "ti-circle" -%}
<div class="art-field art-v{{ variant or 1 }}" aria-hidden="true">
  <svg class="art-rings" viewBox="0 0 280 160" preserveAspectRatio="xMidYMid slice">
    <rect width="280" height="160" fill="var(--bg-tint)"/>
    {%- if (variant or 1) == 1 -%}
      <circle cx="140" cy="80" r="58" fill="none" stroke="var(--topic-color)" stroke-width="0.75" opacity="0.30"/>
      <circle cx="140" cy="80" r="40" fill="none" stroke="var(--topic-color)" stroke-width="0.75" opacity="0.45"/>
    {%- elif (variant or 1) == 2 -%}
      <circle cx="140" cy="80" r="60" fill="none" stroke="var(--topic-color)" stroke-width="0.75" opacity="0.22" stroke-dasharray="3,4"/>
      <circle cx="140" cy="80" r="34" fill="none" stroke="var(--topic-color)" stroke-width="0.75" opacity="0.40"/>
    {%- else -%}
      <line x1="40" y1="80" x2="240" y2="80" stroke="var(--topic-color)" stroke-width="0.75" opacity="0.25"/>
      <circle cx="140" cy="80" r="44" fill="none" stroke="var(--topic-color)" stroke-width="0.75" opacity="0.38"/>
    {%- endif -%}
  </svg>
  <i class="ti {{ icon }} art-icon" style="color: var(--topic-color);"></i>
</div>
{%- endmacro -%}
