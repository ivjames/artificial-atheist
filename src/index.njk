---
layout: base.njk
permalink: /
---
{% from "art.njk" import art %}
{%- set posts = collections.posts -%}
<div class="wrap">

  {% if posts.length %}
  {%- set lead = posts[0] -%}
  {%- set lt = site.topics[lead.data.topic | lower] -%}
  <section class="lead" style="--topic-color: {{ lt.light }};">
    <style>[data-theme="dark"] .lead { --topic-color: {{ lt.dark }}; }</style>
    <a class="lead-img" href="{{ lead.url }}">{{ art(lead.data.topic, 1) }}</a>
    <div class="lead-content">
      <span class="tag" style="color: var(--topic-color);"><i class="ti {{ lt.icon }}"></i> {{ lt.name }} · Featured</span>
      <h1><a href="{{ lead.url }}">{{ lead.data.title }}</a></h1>
      <p class="lead-deck">{{ lead.data.excerpt }}</p>
      <div class="meta">
        <span><i class="ti ti-calendar"></i>{{ lead.date | readableDate }}</span>
        <span><i class="ti ti-clock"></i>{{ lead.templateContent | readingTime }} min read</span>
        <a class="read-link" href="{{ lead.url }}">Read <i class="ti ti-arrow-right" style="font-size:14px;"></i></a>
      </div>
    </div>
  </section>
  {% endif %}

  {% if posts.length > 1 %}
  <div class="eyebrow">Recent articles</div>
  <div class="cards">
    {% for post in posts.slice(1, 4) %}
    {%- set pt = site.topics[post.data.topic | lower] -%}
    <a class="card" href="{{ post.url }}">
      <div class="card-img">{{ art(post.data.topic, 2) }}</div>
      <div class="card-body" style="--topic-color: {{ pt.light }};">
        <style>[data-theme="dark"] .card-body { --topic-color: {{ pt.dark }}; }</style>
        <span class="tag" style="color: var(--topic-color);"><i class="ti {{ pt.icon }}"></i> {{ pt.name }}</span>
        <span class="card-title">{{ post.data.title }}</span>
        <span class="card-excerpt">{{ post.data.excerpt }}</span>
        <span class="card-meta"><i class="ti ti-clock"></i> {{ post.templateContent | readingTime }} min · {{ post.date | shortDate }}</span>
      </div>
    </a>
    {% endfor %}
  </div>
  {% endif %}

  <div class="split">
    <div>
      <div class="eyebrow">Also worth reading</div>
      <div class="list">
        {% for post in posts.slice(4, 8) %}
        {%- set pt = site.topics[post.data.topic | lower] -%}
        <a class="list-item" href="{{ post.url }}">
          <div class="list-thumb">{{ art(post.data.topic, 3) }}</div>
          <div style="--topic-color: {{ pt.light }};">
            <style>[data-theme="dark"] .list-item div { --topic-color: {{ pt.dark }}; }</style>
            <span class="tag" style="color: var(--topic-color);"><i class="ti {{ pt.icon }}"></i> {{ pt.name }}</span>
            <div class="list-title">{{ post.data.title }}</div>
            <div class="list-meta">{{ post.templateContent | readingTime }} min · {{ post.date | shortDate }}</div>
          </div>
        </a>
        {% endfor %}
      </div>
    </div>
    <div>
      <div class="eyebrow">Browse by topic</div>
      <div class="topics-col">
        {% for key, tp in site.topics %}
        <a class="topic-card" href="/topics/{{ key }}/">
          <div class="topic-ic" style="background: {{ tp.tintLight }};"><i class="ti {{ tp.icon }}" style="color: {{ tp.light }};"></i></div>
          <div>
            <div class="topic-name">{{ tp.name }}</div>
            <div class="topic-count">{{ collections[key].length }} article{% if collections[key].length != 1 %}s{% endif %}</div>
          </div>
        </a>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="about-block">
    <h3>About Artificial Atheist</h3>
    <p>{{ site.description }} Every article is generated and curated with AI, then organized for clarity and rigour — an experiment in what machine-authored inquiry can look like.</p>
  </div>

</div>
