---
layout: base.njk
pagination:
  data: site.topics
  size: 1
  alias: topicKey
permalink: "/topics/{{ topicKey }}/"
eleventyComputed:
  title: "{{ site.topics[topicKey].name }}"
---
{% from "art.njk" import art, thumb %}
{%- set tp = site.topics[topicKey] -%}
{%- set posts = collections[topicKey] -%}
<div class="wrap">
  <div class="archive-head" style="--topic-color: {{ tp.light }};">
    <style>[data-theme="dark"] .archive-head { --topic-color: {{ tp.dark }}; }</style>
    <h1><i class="ti {{ tp.icon }}" style="color: var(--topic-color);"></i> {{ tp.name }}</h1>
  </div>

  {% if posts.length %}
  <div class="cards">
    {% for post in posts %}
    <a class="card" href="{{ post.url }}">
      <div class="card-img">{{ thumb(post, site.topics) }}</div>
      <div class="card-body" style="--topic-color: {{ tp.light }};">
        <span class="tag" style="color: var(--topic-color);"><i class="ti {{ tp.icon }}"></i> {{ tp.name }}</span>
        <span class="card-title">{{ post.data.title }}</span>
        <span class="card-excerpt">{{ post.data.excerpt }}</span>
        <span class="card-meta"><i class="ti ti-clock"></i> {{ post.templateContent | readingTime }} min · {{ post.date | shortDate }}</span>
      </div>
    </a>
    {% endfor %}
  </div>
  {% else %}
  <p style="color: var(--text-soft);">No articles in this topic yet.</p>
  {% endif %}
</div>
