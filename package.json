{
  "name": "artificial-atheist",
  "version": "1.0.0",
  "description": "Artificial Atheist — an AI-authored publication on atheism, skepticism, and critical thinking.",
  "type": "module",
  "scripts": {
    "build": "rm -rf _site.new _site.prev && eleventy --output _site.new && pagefind --site _site.new && (mv _site _site.prev 2>/dev/null || true) && mv _site.new _site",
    "serve": "eleventy --serve",
    "generate": "node scripts/generate.mjs",
    "generate:test": "AA_PROVIDER=mock node scripts/generate.mjs --dry-run",
    "compare": "node scripts/compare.mjs",
    "admin": "node tools/admin/server.mjs",
    "illustrate": "node scripts/illustrate.mjs",
    "buffer": "node scripts/buffer.mjs"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "pagefind": "^1.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "luxon": "^3.5.0",
    "markdown-it": "^14.1.0",
    "openai": "^4.0.0"
  }
}
